# ============ LLM 配置 ============
# ⚠️ 安全提醒：
#   1. 复制本文件为 .env 后再填写真实密钥：cp .env.example .env
#   2. .env 已被 .gitignore 忽略，不会被提交到 Git
#   3. 切勿将真实 API Key 写入 .env.example 或任何已追踪的文件
#
# 支持任意 OpenAI 兼容 API（CodeBuddy / OpenAI / DeepSeek / Moonshot 等）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4

# LLM 超时和重试
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2

# ============ 应用配置 ============
APP_NAME=AI Dev System
DEBUG=True
LOG_LEVEL=INFO
