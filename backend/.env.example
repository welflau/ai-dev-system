# ── 服务器 ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── 数据库 ──────────────────────────────────────────────────────────────────
DB_PATH=./data/ai_dev_system.db

# ── LLM API 模式（anthropic / openai）────────────────────────────────────────
# 与 CLI 模式二选一，两套配置可并存，通过 LLM_API_FORMAT 切换
LLM_API_FORMAT=anthropic
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=claude-sonnet-4-5
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ── LLM CLI 模式（LLM_API_FORMAT=cli 时生效）─────────────────────────────────
# cli_type: claude / codebuddy / custom
# cli_cmd:  工具在 PATH 中可直接写名称，否则填完整路径（Windows 含 .exe）
# cli_model: 留空则复用 LLM_MODEL；各工具支持的模型名称以官方文档为准
# cli_timeout: 子进程最大等待秒数，复杂任务可适当调大
#
# LLM_API_FORMAT=cli
# LLM_CLI_TYPE=claude
# LLM_CLI_CMD=claude
# LLM_CLI_MODEL=
# LLM_CLI_TIMEOUT=120
#
# CodeBuddy 示例：
# LLM_API_FORMAT=cli
# LLM_CLI_TYPE=codebuddy
# LLM_CLI_CMD=codebuddy
# LLM_CLI_MODEL=
# LLM_CLI_TIMEOUT=120

# ── 预算约束 ─────────────────────────────────────────────────────────────────
AGENT_MAX_TOKENS=200000
AGENT_MAX_TURNS=50
AGENT_MAX_SECONDS=600
CHAT_MAX_TOKENS=300000
CHAT_MAX_TURNS=50
CHAT_MAX_SECONDS=300

# ── 知识库 / 资产库（可选）───────────────────────────────────────────────────
# GLOBAL_KNOWLEDGE_REPO_URL=https://github.com/your-org/G_DesignKnowledge.git
# GLOBAL_KNOWLEDGE_LOCAL_PATH=./G_DesignKnowledge
# GLOBAL_KNOWLEDGE_AUTO_PUSH=false
# ART_ASSETS_REPO_URL=https://github.com/your-org/G_ArtRes.git
# ART_ASSETS_LOCAL_PATH=./G_ArtRes
# ART_ASSETS_AUTO_PUSH=false

# ── 图片生成（可选）──────────────────────────────────────────────────────────
# LIGHTAI_API_BASE=https://api.lightai.woa.com
# LIGHTAI_API_KEY=
# LIGHTAI_IMAGE_ENGINE=gemini
# LIGHTAI_IMAGE_TIMEOUT=300
# PEXELS_API_KEY=
# PIXABAY_API_KEY=
