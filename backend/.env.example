# ============ LLM 配置 ============
# 支持任意 OpenAI 兼容 API（CodeBuddy / OpenAI / DeepSeek / Moonshot 等）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4

# LLM 超时和重试
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2

# ============ 应用配置 ============
APP_NAME=AI Dev System
DEBUG=True
LOG_LEVEL=INFO
