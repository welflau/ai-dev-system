{
  "react-dev": {
    "name": "React/HTML 开发",
    "description": "React Hooks、组件命名、内联到 index.html 的模式",
    "prompt_file": "packs/react_dev/prompt.md",
    "inject_to": ["DevAgent"],
    "priority": "high",
    "enabled": true,
    "traits_match": {
      "any_of": ["framework:react", "platform:web"]
    },
    "paths": ["**/*.html", "**/*.jsx", "**/*.tsx", "**/*.js", "**/*.ts"]
  },
  "fastapi-dev": {
    "name": "FastAPI 后端开发",
    "description": "async 路由、依赖注入、SQLite 异步访问、错误处理",
    "prompt_file": "packs/fastapi_dev/prompt.md",
    "inject_to": ["DevAgent"],
    "priority": "high",
    "enabled": true,
    "traits_match": {
      "any_of": ["framework:fastapi"]
    }
  },
  "playwright-e2e": {
    "name": "Playwright 端到端测试",
    "description": "截图、等待策略、断言、跨浏览器兼容",
    "prompt_file": "packs/playwright_e2e/prompt.md",
    "inject_to": ["TestAgent", "ProductAgent"],
    "priority": "high",
    "enabled": true,
    "traits_match": {
      "any_of": ["platform:web", "platform:wechat"]
    }
  },
  "git-workflow": {
    "name": "Git 工程化",
    "description": "feat/develop/main 分支策略、提交消息规范、PR 流程",
    "prompt_file": "packs/git_workflow/prompt.md",
    "inject_to": ["DevAgent", "DeployAgent"],
    "priority": "medium",
    "enabled": true,
    "traits_match": {
      "any_of": ["vcs:git"]
    }
  },
  "unreal-cpp-dev": {
    "name": "Unreal Engine C++ 开发",
    "description": "UE C++ 规范：UCLASS/UPROPERTY/UFUNCTION 宏、类型系统、Build.cs 依赖、UHT 常见坑",
    "prompt_file": "packs/unreal_cpp_dev/prompt.md",
    "inject_to": ["DevAgent"],
    "priority": "high",
    "enabled": true,
    "traits_match": {
      "any_of": ["engine:ue5", "engine:ue4"]
    },
    "paths": ["Source/**/*.h", "Source/**/*.cpp", "**/*.Build.cs"]
  },
  "unreal-project": {
    "name": "Unreal Engine 项目结构",
    "description": "UE 项目布局（Source/Content/Config）、模块划分、.uproject/Target.cs 配置、修改原则",
    "prompt_file": "packs/unreal_project/prompt.md",
    "inject_to": ["DevAgent", "ArchitectAgent"],
    "priority": "medium",
    "enabled": true,
    "traits_match": {
      "any_of": ["engine:ue5", "engine:ue4"]
    }
  }
}