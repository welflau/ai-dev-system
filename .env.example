# AI 自动开发系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============ LLM 配置 ============
# OpenAI 兼容 API 地址（必填，否则使用规则引擎降级）
LLM_BASE_URL=https://api.openai.com/v1
# API Key（必填）
LLM_API_KEY=sk-your-api-key-here
# 模型名称
LLM_MODEL=gpt-4
# 超时秒数
LLM_TIMEOUT=60
# 最大重试次数
LLM_MAX_RETRIES=3

# ============ 服务配置 ============
HOST=0.0.0.0
PORT=8000
DEBUG=true
